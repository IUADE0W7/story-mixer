APP_NAME=LoreForge API
APP_VERSION=0.1.0

# Keep false in production and manage schema with Alembic.
AUTO_CREATE_SCHEMA=false

# Set true for local deterministic generation/judging without external model calls.
USE_STUB_LLM=false

# Guard for the live provider smoke endpoint at /api/v1/stories/smoke/provider.
ENABLE_REAL_PROVIDER_SMOKE=false
REAL_PROVIDER_SMOKE_PROMPT=Write a compact two-sentence noir opening with calibrated narrative tone.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/loreforge

# Provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local model endpoint
# Leave OLLAMA_BASE_URL unset to use automatic defaults:
# - Native Linux/macOS: http://localhost:11434
# - WSL with Ollama on Windows host: http://<windows-host-ip>:11434
# OLLAMA_BASE_URL=http://localhost:11434
# Optional override used only for WSL autodetection fallback:
# WINDOWS_HOST_IP=172.22.224.1

# Optional test-only flags for tests/test_real_provider_smoke.py
# RUN_REAL_PROVIDER_SMOKE=true
#
# Logging
# LOG_LEVEL=DEBUG
#
# Ollama (local / Windows-hosted via WSL):
# REAL_SMOKE_PROVIDER=ollama
# REAL_SMOKE_MODEL=llama3.2:3b
# REAL_SMOKE_JUDGE_MODEL=llama3.2:3b
#
# OpenAI:
# REAL_SMOKE_PROVIDER=openai
# REAL_SMOKE_MODEL=gpt-4o-mini
# REAL_SMOKE_JUDGE_MODEL=gpt-4o-mini
#
# Anthropic:
# REAL_SMOKE_PROVIDER=anthropic
# REAL_SMOKE_MODEL=claude-3-haiku-20240307
# REAL_SMOKE_JUDGE_MODEL=claude-3-haiku-20240307
#
# Google Gemini:
# REAL_SMOKE_PROVIDER=gemini
# REAL_SMOKE_MODEL=gemini-1.5-flash
# REAL_SMOKE_JUDGE_MODEL=gemini-1.5-flash
#
# REAL_SMOKE_PROMPT=Write a one-paragraph cinematic opening.
