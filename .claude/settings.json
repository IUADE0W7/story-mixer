{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(make:*)",
      "Bash(pytest:*)",
      "Bash(alembic:*)",
      "Bash(curl:*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 /home/mikha/projects/story-mixer/.claude/hooks/lint_ts.py 2>/dev/null || true",
            "statusMessage": "ESLint fixing TypeScript..."
          }
        ]
      }
    ]
  }
}
